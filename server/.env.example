# ─── PostgreSQL (AWS RDS compatible) ─────────────────────────────────────────
#
# Local development:
#   DB_HOST=localhost
#
# AWS RDS:
#   DB_HOST=your-rds-instance.xxxxxxxxxxxx.ap-south-1.rds.amazonaws.com
#
# The NODE_ENV=production flag automatically enables SSL for RDS connections.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=careernest_portal

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # set to 'production' on AWS EC2 / ECS

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin – React dev server locally, or deployed CloudFront / S3 domain
CLIENT_ORIGIN=http://localhost:5173

# ─── AWS (production hints) ───────────────────────────────────────────────────
# NODE_ENV=production
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_USER=careernest_admin
# DB_PASSWORD=<strong-rds-password>
# DB_NAME=careernest_portal
# CLIENT_ORIGIN=https://your-cloudfront-domain.cloudfront.net
