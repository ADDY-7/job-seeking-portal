# ─── MongoDB Atlas ───────────────────────────────────────
# Replace with your Atlas cluster URI
# e.g. mongodb+srv://USERNAME:PASSWORD@cluster0.xxxx.mongodb.net/careernest?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/careernest?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
# Use a long random string (openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────
# Frontend origin (React dev server or deployed domain)
CLIENT_ORIGIN=http://localhost:5173

# ─── AWS (for production) ────────────────────────────────
# These are used when deploying on EC2 / behind ALB
# AWS_REGION=ap-south-1
# AWS_SECRET_NAME=careernest/prod/env
